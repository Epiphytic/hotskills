{
  "name": "@epiphytic/hotskills-server",
  "version": "0.1.0",
  "description": "MCP server for hotskills \u2014 skill management for Claude Code",
  "type": "module",
  "main": "./dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/schemas',{recursive:true});cpSync('src/schemas/config.v1.json','dist/schemas/config.v1.json');cpSync('src/schemas/state.v1.json','dist/schemas/state.v1.json');\"",
    "dev": "tsc --watch",
    "test": "node --test dist/__tests__/smoke.test.js dist/__tests__/tools.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3"
  }
}
